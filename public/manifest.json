{
  "name": "Realth - Running & Health Tracker",
  "short_name": "Realth",
  "description": "Track your running progress with Strava integration, biometric analysis, and VO2Max insights",
  "start_url": "/dashboard",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "browser"],
  "background_color": "#0f172a",
  "theme_color": "#16a34a",
  "orientation": "portrait-primary",
  "lang": "en",
  "icons": [
    {
      "src": "/api/icon-192",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/api/icon-512",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/api/icon-512",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any"
    }
  ],
  "categories": ["health", "fitness", "sports"],
  "shortcuts": [
    {
      "name": "Add Activity",
      "short_name": "Add Run",
      "description": "Log a new running activity",
      "url": "/dashboard/add-activity"
    },
    {
      "name": "Activities",
      "short_name": "Activities",
      "description": "View all synced activities",
      "url": "/dashboard/activities"
    },
    {
      "name": "Profile",
      "short_name": "Profile",
      "description": "View your fitness profile",
      "url": "/dashboard/profile"
    }
  ],
  "prefer_related_applications": false
}
